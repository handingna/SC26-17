# 复制此文件为 .env.local 后填写 OpenAI 兼容模型服务配置。
# .env.local 不应提交到 Git；切勿把真实 Key 写入源码、浏览器或客户端请求。

AI_API_KEY=replace-with-your-api-key
AI_MODEL=your-model-id
AI_BASE_URL=https://your-provider.example/v1
AI_PROVIDER_NAME=Your Provider

# 仅当应用部署在会覆盖并可信传递客户端 IP 的反向代理之后时启用。
# 课程本机演示保持 false；否则客户端可伪造转发头绕过单进程限流。
TRUST_PROXY_HEADERS=false

# 一次版本内兼容旧配置。只有在完全未设置 AI_API_KEY、AI_MODEL、AI_BASE_URL 时，
# 才会整组读取这些变量；AI_PROVIDER_NAME 只是显示标签，不参与配置组选择。
# 不会把 AI_* 与 DEEPSEEK_* 交叉拼接成一套配置。
# DEEPSEEK_API_KEY=replace-with-your-api-key
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
